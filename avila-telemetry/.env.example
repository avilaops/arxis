# ============================================
# ARKANA STORE - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE
# ============================================
MONGO_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/

# ============================================
# PAYMENT GATEWAYS
# ============================================
PAYPAL_ID=your_paypal_id
PAYPAL_TOKEN_API=your_paypal_token

STRIPE_API=your_stripe_api_key

# ============================================
# AI / ML SERVICES
# ============================================
OPENAI_API_KEY=your_openai_api_key
HF_TOKEN=your_huggingface_token
LANGSMITH_API_KEY=your_langsmith_key

# ============================================
# MONITORING & TOOLS
# ============================================
SENTRY_TOKEN_API=your_sentry_token
GH_TOKEN=your_github_token
NGROK=your_ngrok_token
IMAZING=your_imazing_key

# ============================================
# GOOGLE CLOUD
# ============================================
GCLOUD_API_TOKEN=your_gcloud_api_token
GCLOUD_CLIENT=your_gcloud_client_id
GCLOUD_SECRET_KEY=your_gcloud_secret
GCLOUD_MAPS_ID=your_maps_id

# ============================================
# CLOUDFLARE
# ============================================
CLOUDFLARE_API=your_cloudflare_api
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_GLOBAL_API_KEY=your_global_key
CLOUDFLARE_ORIGIN_CA_KEY=your_origin_ca_key

# ============================================
# UNITY
# ============================================
UNITY_EMAIL=your_unity_email
UNITY_PASSWORD=your_unity_password
UNITY_LICENSE=your_unity_license_xml

# ============================================
# GRAVATAR
# ============================================
GRAVATAR_EMAIL=your_gravatar_email
