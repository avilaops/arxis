#[test]
fn test_groupby_first_last() {
    let df = DataFrame::new(vec![
        Series::new("key", vec!["A", "B", "A", "B"]),
        Series::new("value", vec![1.0, 2.0, 3.0, 4.0]),
    ])
    .unwrap();

    let result = df
        .group_by(&["key"])
        .unwrap()
        .agg(&[("value", "first"), ("value", "last")])
        .unwrap();

    assert_eq!(result.height(), 2);
}

#[test]
fn test_groupby_with_nulls() {
    let df = DataFrame::new(vec![
        Series::new("category", vec!["A", "A", "B", "B"]),
        Series::new("value", vec![1.0, f64::NAN, 3.0, 4.0]),
    ])
    .unwrap();

    let result = df
        .group_by(&["category"])
        .unwrap()
        .agg(&[("value", "sum")])
        .unwrap();

    assert_eq!(result.height(), 2);
}

#[test]
fn test_groupby_large_groups() {
    let categories: Vec<&str> = (0..1000).map(|i| if i % 2 == 0 { "Even" } else { "Odd" }).collect();
    let values: Vec<f64> = (0..1000).map(|i| i as f64).collect();

    let df = DataFrame::new(vec![
        Series::new("category", categories),
        Series::new("value", values),
    ])
    .unwrap();

    let result = df
        .group_by(&["category"])
        .unwrap()
        .agg(&[("value", "sum"), ("value", "count")])
        .unwrap();

    assert_eq!(result.height(), 2);
}

#[test]
fn test_groupby_all_aggregations() {
    let df = DataFrame::new(vec![
        Series::new("group", vec!["A", "A", "B", "B"]),
        Series::new("value", vec![10.0, 20.0, 30.0, 40.0]),
    ])
    .unwrap();

    let result = df
        .group_by(&["group"])
        .unwrap()
        .agg(&[
            ("value", "sum"),
            ("value", "mean"),
            ("value", "min"),
            ("value", "max"),
            ("value", "std"),
            ("value", "count"),
        ])
        .unwrap();

    assert_eq!(result.height(), 2);
    assert!(result.width() >= 6);
}
