//! I/O operation tests

use avila_dataframe::prelude::*;
use std::fs;
use tempfile::TempDir;

#[test]
fn test_csv_write_read_roundtrip() {
    let temp_dir = TempDir::new().unwrap();
    let file_path = temp_dir.path().join("test.csv");

    let df = DataFrame::new(vec![
        Series::new("a", vec![1.0, 2.0, 3.0]),
        Series::new("b", vec![4.0, 5.0, 6.0]),
    ])
    .unwrap();

    df.write_csv(file_path.to_str().unwrap()).unwrap();

    let df_read = DataFrame::read_csv(file_path.to_str().unwrap()).unwrap();

    assert_eq!(df_read.height(), 3);
    assert_eq!(df_read.width(), 2);
}

#[test]
fn test_csv_write_with_headers() {
    let temp_dir = TempDir::new().unwrap();
    let file_path = temp_dir.path().join("headers.csv");

    let df = DataFrame::new(vec![
        Series::new("name", vec!["Alice", "Bob", "Charlie"]),
        Series::new("age", vec![25.0, 30.0, 35.0]),
    ])
    .unwrap();

    df.write_csv(file_path.to_str().unwrap()).unwrap();

    let contents = fs::read_to_string(&file_path).unwrap();
    assert!(contents.contains("name"));
    assert!(contents.contains("age"));
}

#[test]
fn test_csv_read_with_types() {
    let temp_dir = TempDir::new().unwrap();
    let file_path = temp_dir.path().join("types.csv");

    fs::write(&file_path, "int,float,string\n1,1.5,hello\n2,2.5,world").unwrap();

    let df = DataFrame::read_csv(file_path.to_str().unwrap()).unwrap();

    assert_eq!(df.height(), 2);
    assert_eq!(df.width(), 3);
}

#[test]
fn test_csv_empty_file() {
    let temp_dir = TempDir::new().unwrap();
    let file_path = temp_dir.path().join("empty.csv");

    fs::write(&file_path, "").unwrap();

    let result = DataFrame::read_csv(file_path.to_str().unwrap());
    assert!(result.is_err() || result.unwrap().height() == 0);
}

#[cfg(feature = "json")]
#[test]
fn test_json_write_read_roundtrip() {
    let temp_dir = TempDir::new().unwrap();
    let file_path = temp_dir.path().join("test.json");

    let df = DataFrame::new(vec![
        Series::new("id", vec![1.0, 2.0, 3.0]),
        Series::new("value", vec![10.0, 20.0, 30.0]),
    ])
    .unwrap();

    df.write_json(file_path.to_str().unwrap()).unwrap();

    let df_read = DataFrame::read_json(file_path.to_str().unwrap()).unwrap();

    assert_eq!(df_read.height(), 3);
}

#[cfg(feature = "json")]
#[test]
fn test_json_pretty_print() {
    let temp_dir = TempDir::new().unwrap();
    let file_path = temp_dir.path().join("pretty.json");

    let df = DataFrame::new(vec![
        Series::new("x", vec![1.0, 2.0]),
    ])
    .unwrap();

    df.write_json(file_path.to_str().unwrap()).unwrap();

    let contents = fs::read_to_string(&file_path).unwrap();
    assert!(contents.len() > 0);
}

#[test]
fn test_csv_large_file() {
    let temp_dir = TempDir::new().unwrap();
    let file_path = temp_dir.path().join("large.csv");

    let values: Vec<f64> = (0..10000).map(|i| i as f64).collect();
    let df = DataFrame::new(vec![
        Series::new("id", values),
    ])
    .unwrap();

    df.write_csv(file_path.to_str().unwrap()).unwrap();

    let df_read = DataFrame::read_csv(file_path.to_str().unwrap()).unwrap();

    assert_eq!(df_read.height(), 10000);
}

#[test]
fn test_csv_special_characters() {
    let temp_dir = TempDir::new().unwrap();
    let file_path = temp_dir.path().join("special.csv");

    let df = DataFrame::new(vec![
        Series::new("text", vec!["hello,world", "foo\"bar", "baz\nqux"]),
    ])
    .unwrap();

    df.write_csv(file_path.to_str().unwrap()).unwrap();

    let df_read = DataFrame::read_csv(file_path.to_str().unwrap()).unwrap();

    assert_eq!(df_read.height(), 3);
}

#[test]
fn test_csv_unicode() {
    let temp_dir = TempDir::new().unwrap();
    let file_path = temp_dir.path().join("unicode.csv");

    let df = DataFrame::new(vec![
        Series::new("text", vec!["こんにちは", "你好", "안녕하세요"]),
    ])
    .unwrap();

    df.write_csv(file_path.to_str().unwrap()).unwrap();

    let df_read = DataFrame::read_csv(file_path.to_str().unwrap()).unwrap();

    assert_eq!(df_read.height(), 3);
}

#[test]
fn test_csv_missing_values() {
    let temp_dir = TempDir::new().unwrap();
    let file_path = temp_dir.path().join("missing.csv");

    fs::write(&file_path, "a,b\n1,2\n3,\n,5").unwrap();

    let df = DataFrame::read_csv(file_path.to_str().unwrap()).unwrap();

    assert_eq!(df.height(), 3);
}

#[test]
fn test_csv_custom_delimiter() {
    let temp_dir = TempDir::new().unwrap();
    let file_path = temp_dir.path().join("delim.tsv");

    fs::write(&file_path, "a\tb\n1\t2\n3\t4").unwrap();

    // Assuming there's a way to specify delimiter
    let result = DataFrame::read_csv(file_path.to_str().unwrap());
    assert!(result.is_ok());
}

#[test]
fn test_write_to_string() {
    let df = DataFrame::new(vec![
        Series::new("a", vec![1.0, 2.0]),
    ])
    .unwrap();

    let csv_string = df.to_csv_string().unwrap();
    assert!(csv_string.contains("a"));
    assert!(csv_string.contains("1"));
}

#[test]
fn test_read_from_string() {
    let csv_data = "x,y\n1,2\n3,4";

    let df = DataFrame::from_csv_string(csv_data).unwrap();

    assert_eq!(df.height(), 2);
    assert_eq!(df.width(), 2);
}

#[cfg(feature = "compression")]
#[test]
fn test_compressed_csv() {
    let temp_dir = TempDir::new().unwrap();
    let file_path = temp_dir.path().join("data.csv.gz");

    let df = DataFrame::new(vec![
        Series::new("id", vec![1.0, 2.0, 3.0]),
    ])
    .unwrap();

    df.write_compressed_csv(file_path.to_str().unwrap()).unwrap();

    let df_read = DataFrame::read_compressed_csv(file_path.to_str().unwrap()).unwrap();

    assert_eq!(df_read.height(), 3);
}
